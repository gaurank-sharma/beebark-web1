# Base URL of the backend API/socket server.
# Leave empty in production if the frontend is served from the same origin as the backend.
REACT_APP_BACKEND_URL=http://localhost:8001

# Google Sign-In (optional — leave empty to hide the Google button).
# Must match GOOGLE_CLIENT_ID on the backend.
REACT_APP_GOOGLE_CLIENT_ID=

# LinkedIn Sign-In (optional — leave empty to hide the LinkedIn button).
# The LinkedIn app's Client ID (the secret stays on the backend only).
REACT_APP_LINKEDIN_CLIENT_ID=
