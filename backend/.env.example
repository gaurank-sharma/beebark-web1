# Server Configuration
PORT=8001
APP_URL=http://localhost:3000
# Comma-separated list of allowed origins (no trailing slash). Use specific domains in production.
CORS_ORIGINS=http://localhost:3000

# Database
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
DB_NAME=beebark

# Security — generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret

# Cloudinary (Images and Resumes)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (OTP, welcome, password resets)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=you@example.com

# Optional mail relay (use when the host blocks outbound SMTP, e.g. Render free).
# Point this at the deployed mail-service (Vercel). When set, all email is sent
# through it over HTTPS instead of direct SMTP. MAIL_SHARED_SECRET must match
# the value configured on the mail service.
MAIL_SERVICE_URL=
MAIL_SHARED_SECRET=

# Google Sign-In (optional — leave empty to disable the Google button)
# OAuth 2.0 Web client ID from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# LinkedIn Sign-In (optional — leave empty to disable the LinkedIn button)
# From a LinkedIn app with the "Sign In with LinkedIn using OpenID Connect" product.
# Authorized redirect URL must be: <APP_URL>/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Firebase phone (SMS) sign-in (optional). The full service-account JSON from
# Firebase console → Project settings → Service accounts → Generate new private
# key, pasted as a single-line string. Backend only.
FIREBASE_SERVICE_ACCOUNT=

# AI Job Matching / LLM (optional — falls back to keyword matching if unset)
OPENAI_API_KEY=
